# Copy to .env for local dev. In production, set these as GitHub Actions
# repository secrets (Settings → Secrets and variables → Actions).

# ---- Upload-Post (the multi-platform poster) -----------------------------
# Sign up at https://upload-post.com → API → create a key.
UPLOAD_POST_API_KEY=apikey_REPLACE_ME

# The "profile name" in your Upload-Post dashboard. One profile = one set of
# connected social accounts. Create a profile for Home Advisor Locksmith and
# connect its Instagram + Facebook Page + Google Business.
UPLOAD_POST_USER=home-advisor-locksmith

# Belt-and-suspenders safety: comma-separated platform:handle pairs the agent
# verifies before every post. Aborts if Upload-Post's profile is wired to the
# wrong account (e.g. someone else's IG got OAuth'd by accident).
UPLOAD_POST_EXPECTED_HANDLES=instagram:homeadvisorlocksmith,facebook:Home Advisor Locksmith,google_business:Home Advisor Locksmith

# Facebook Page ID is REQUIRED when posting to Facebook to prevent posts from
# landing on the wrong Page if you manage multiple. Get it from
# https://api.upload-post.com/api/uploadposts/facebook/pages?profile=home-advisor-locksmith
# or your FB Page → About → Page transparency → Page ID.
FACEBOOK_PAGE_ID=

# ---- Google Business Profile (multi-location) ---------------------------
# You manage several Business Profiles under one Google login. Upload-Post
# can't guess which one a post is for, so you MUST pick a location.
#
#   1. Run:  npm run gbp:locations
#   2. Copy the `name` of the location you want (looks like
#      "accounts/123456789/locations/987654321")
#   3. Paste it below. ONE location per run — to post a different location,
#      change this value (or run a second copy of the agent with its own value).
GBP_LOCATION_ID=

# ---- OpenAI image generation (optional) ---------------------------------
# Used only for posts that have media.source = 'ai' in posts.ts. If unset,
# those posts error (switch them to a real asset, or add the key).
OPENAI_API_KEY=sk-...REPLACE_ME

# ---- Optional: explicit timezone for log readability --------------------
TZ=America/New_York
