# Copy to .env for local dev. In production, set these as GitHub Actions
# repository secrets (Settings → Secrets and variables → Actions).

# ---- Claude (drafts the article) ----------------------------------------
# Create at https://console.anthropic.com → Settings → API Keys.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ---- OpenAI (generates the hero image) ----------------------------------
# Same key the social agent uses. https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...REPLACE_ME

# ---- Site URL (canonical links + sitemap) -------------------------------
# Defaults to https://www.homeadvisorlocksmith.com if unset. Change only if
# you move domains — no code edits needed.
SITE_URL=https://www.homeadvisorlocksmith.com
